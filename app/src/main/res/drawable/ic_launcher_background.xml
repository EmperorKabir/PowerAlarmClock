<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background layer. Solid teal `#00C2B8` is the brand primary
  defined in core/ui PowerAlarmTheme. Adaptive-icon system masks (square /
  squircle / circle / round / teardrop) all crop within the inner 72dp circle —
  using a flat fill guarantees no artefacts at any mask shape.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:fillColor="#00C2B8"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

    <!-- Subtle radial highlight for depth (still flat-cartoon style). -->
    <path
        android:fillAlpha="0.18"
        android:fillColor="#FFFFFF"
        android:pathData="M54,54 m-46,0 a46,46 0 1,0 92,0 a46,46 0 1,0 -92,0" />
</vector>
