<?xml version="1.0" encoding="utf-8"?>
<!--
  Themed-icon monochrome layer (Android 13+ themed icons API). The launcher
  tints this drawable to match the user's wallpaper palette, so all paths must
  be the same colour. Composition mirrors ic_launcher_foreground but flattened
  to a single tint-friendly silhouette.
-->
